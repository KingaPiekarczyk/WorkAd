@page "/"
@using WorkAd.Data
@inject WorkAdvertService WorkAdvertService

<PageTitle>Get Job</PageTitle>

<div class="container">
    <h1>Work offers</h1>

    <div class="mb-4">
        <a href="/add-workadvert" class="btn btn-primary">Add</a>
        <a href="/delete-workadvert" class="btn btn-primary">Delete</a>
        <a href="/edit-workadvert" class="btn btn-primary">Edit</a>
    </div>

    @if (adverts == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loadinggg...</span>
            </div>
        </div>
    }
    else if (!adverts.Any())
    {
        <div class="alert alert-info">


            No ads to display. Add your first work advert!
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var ad in adverts)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0" style="background: #F3F8FF;">

                        <div class="card-header bg-primary bg-opacity-25 border-0">
                            <h4 class="fw-bold mb-0">@ad.Title</h4>
                        </div>

                        <div class="card-body">
                            <div class="text-muted mb-2">
                                @($"{ad.HourlyRate:0.00} zł / h") • @ad.Location
                            </div>

                            <p class="mb-3">@ad.Description</p>

                            <div class="small text-muted">
                                <strong>Work type:</strong> @ad.WorkType<br />
                                <strong>Contract:</strong> @ad.ContractType
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 text-end">
                            <small class="text-muted">
                                Added: @ad.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>

                    </div>
                </div>




            }
        </div>
    }
</div>

@code {
    private List<WorkAdvert>? adverts;

    protected override async Task OnInitializedAsync()
    {
        adverts = await WorkAdvertService.GetAllWorkAdvertsAsync();
    }
}
