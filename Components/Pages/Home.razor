@page "/"
@using WorkAd.Data
@inject WorkAdvertService WorkAdvertService

<PageTitle>Get Job</PageTitle>

<div class="container">
    <h1>Work offers</h1>

    <div class="mb-4">
        <a href="/add-workadvert" class="btn btn-primary">Add</a>
        <a href="/delete-workadvert" class="btn btn-primary">Delete</a>
        <a href="/edit-workadvert" class="btn btn-primary">Edit</a>
    </div>

    @if (adverts == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loadinggg...</span>
            </div>
        </div>
    }
    else if (!adverts.Any())
    {
        <div class="alert alert-info">


            No ads to display. Add your first work advert!
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var ad in adverts)
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@ad.Title</h5>

                            <h6 class="card-subtitle mb-2 text-muted">
                                @($"{ad.HourlyRate:0.00} zł / h")
                            </h6>

                            <p class="card-text">@ad.Description</p>

                            <p class="card-text">
                                <strong>Work type:</strong> @ad.WorkType<br />
                                <strong>Contract type:</strong> @ad.ContractType<br />
                                <strong>Location:</strong> @ad.Location
                            </p>
                        </div>

                        <div class="card-footer">
                            <small class="text-muted">
                                Dodano: @ad.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<WorkAdvert>? adverts;

    protected override async Task OnInitializedAsync()
    {
        adverts = await WorkAdvertService.GetAllWorkAdvertsAsync();
    }
}
