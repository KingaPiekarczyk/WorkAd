@page "/delete-workadvert"
@using WorkAd.Data
@using WorkAd.Components
@inject WorkAdvertService WorkAdvertService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Delete Adverts</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <h1 class="fw-semibold mb-0 me-3">Delete adverts</h1>
            <a class="btn btn-secondary" href="/">Back</a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Loading...</p>
        </div>
    }
    else if (adverts == null || !adverts.Any())
    {
        <div class="alert alert-info">No adverts to delete.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var ad in adverts)
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@ad.Title</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@($"{ad.HourlyRate:0.00} zł / h")</h6>
                            <p class="card-text">@ad.Description</p>
                            <p class="card-text">
                                <strong>Work type:</strong> @ad.WorkType<br />
                                <strong>Contract type:</strong> @ad.ContractType<br />
                                <strong>Location:</strong> @ad.Location
                            </p>
                        </div>

                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <small class="text-muted">Added: @ad.CreatedDate.ToString("dd.MM.yyyy HH:mm")</small>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => DeleteAdvert(ad.Id)"
                                    disabled="@(deletingId == ad.Id)">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<WorkAdvert>? adverts;
    private bool isLoading;
    private int? deletingId;

    protected override async Task OnInitializedAsync() => await LoadAdverts();

    private async Task LoadAdverts()
    {
        isLoading = true;
        try
        {
            adverts = await WorkAdvertService.GetAllWorkAdvertsAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAdvert(int id)
    {
        if (deletingId != null) return;

        var ok = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this advert?");
        if (!ok) return;

        try
        {
            deletingId = id;
            var deleted = await WorkAdvertService.DeleteWorkAdvertAsync(id);
            if (deleted)
            {
                adverts?.RemoveAll(a => a.Id == id);
                StateHasChanged();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Could not delete the advert.");
            }
        }
        finally
        {
            deletingId = null;
        }
    }
}
