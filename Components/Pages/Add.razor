@page "/add-workadvert"
@page "/edit-workadvert/{Id:int}"
@using WorkAd.Data
@using WorkAd.Components
@using Microsoft.AspNetCore.Components.Forms
@inject WorkAdvertService WorkAdvertService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Edit Advert" : "Add Advert")</PageTitle>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3">Loading...</p>
    </div>
}
else
{
    <div class="container py-4">
        <div class="card">
            <div class="card-body">
                <h1 class="card-title mb-4">@(IsEdit ? "Edit advert" : "Add advert")</h1>

                <EditForm Model="advert" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <InputText class="form-control" @bind-Value="advert.Title" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-control" @bind-Value="advert.Description" rows="4" />
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Hourly rate</label>
                            <InputNumber class="form-control" @bind-Value="advert.HourlyRate" />
                        </div>
                        <div class="col">
                            <label class="form-label">Location</label>
                            <InputText class="form-control" @bind-Value="advert.Location" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Contract type</label>
                            <InputSelect class="form-select" @bind-Value="advert.ContractType">
                                @foreach (var v in Enum.GetValues<ContractType>())
                                {
                                    <option value="@v">@v</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col">
                            <label class="form-label">Work type</label>
                            <InputSelect class="form-select" @bind-Value="advert.WorkType">
                                @foreach (var v in Enum.GetValues<WorkType>())
                                {
                                    <option value="@v">@v</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
                            @(IsEdit ? "Save changes" : "Add advert")
                        </button>
                        <button class="btn btn-outline-danger ms-2" type="button" @onclick="Cancel" disabled="@isSubmitting">
                            Cancel
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    private WorkAdvert advert = new();
    private bool isLoading = true;
    private bool isSubmitting = false;

    private bool IsEdit => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            try
            {
                isLoading = true;
                var loaded = await WorkAdvertService.GetByIdAsync(Id!.Value);
                if (loaded != null)
                {
                    advert = loaded;
                }
                else
                {
                    NavigationManager.NavigateTo("/");
                }
            }
            finally
            {
                isLoading = false;
            }
        }
        else
        {
            advert = new WorkAdvert();
            isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting) return;
        isSubmitting = true;

        try
        {
            if (IsEdit)
            {
                await WorkAdvertService.UpdateWorkAdvertAsync(advert);
            }
            else
            {
                advert.CreatedDate = DateTime.UtcNow;
                await WorkAdvertService.AddWorkAdvertAsync(advert);
            }

            NavigationManager.NavigateTo("/");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/");
}
